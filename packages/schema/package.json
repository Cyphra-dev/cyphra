{
  "name": "@cyphra/schema",
  "version": "0.0.0",
  "description": "Cyphra schema DSL parser and AST for Neo4j graph models",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:grammar": "peggy --format es -o src/generated/parser.js grammar.peggy",
    "build": "pnpm run build:grammar && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "peggy": "^4.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2"
  }
}
