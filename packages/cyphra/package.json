{
  "name": "cyphra",
  "version": "0.2.0",
  "description": "Central package for Cyphra: schema DSL, Cypher helpers, Neo4j runtime, migrations, and CLI (depends on all @cyphra/* packages)",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cyphra": "./bin/cyphra.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js"
    },
    "./orm": {
      "types": "./dist/orm.d.ts",
      "import": "./dist/orm.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cyphra/cli": "workspace:*",
    "@cyphra/config": "workspace:*",
    "@cyphra/core": "workspace:*",
    "@cyphra/orm": "workspace:*",
    "@cyphra/migrator": "workspace:*",
    "@cyphra/provider-neo4j": "workspace:*",
    "@cyphra/query": "workspace:*",
    "@cyphra/runtime": "workspace:*",
    "@cyphra/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2"
  },
  "keywords": [
    "neo4j",
    "cypher",
    "graph",
    "schema",
    "migrations"
  ],
  "license": "MIT",
  "homepage": "https://www.cyphra.dev",
  "bugs": {
    "url": "https://github.com/cyphra-dev/cyphra/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cyphra-dev/cyphra.git",
    "directory": "packages/cyphra"
  }
}
