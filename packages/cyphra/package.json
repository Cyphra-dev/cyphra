{
  "name": "cyphra",
  "version": "0.0.0",
  "description": "Cyphra monolith: schema DSL, Cypher helpers, Neo4j runtime, and migrations (re-exports @cyphra/*)",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cyphra/migrator": "workspace:*",
    "@cyphra/query": "workspace:*",
    "@cyphra/runtime": "workspace:*",
    "@cyphra/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2"
  },
  "keywords": [
    "neo4j",
    "cypher",
    "graph",
    "schema",
    "migrations"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyphra/cyphra.git",
    "directory": "packages/cyphra"
  }
}
