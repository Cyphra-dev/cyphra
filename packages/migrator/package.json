{
  "name": "@cyphra/migrator",
  "version": "0.0.0",
  "description": "Versioned migrations, batch helpers, and schema push for Cyphra",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cyphra/query": "workspace:*",
    "@cyphra/runtime": "workspace:*",
    "@cyphra/schema": "workspace:*",
    "neo4j-driver": "^5.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2"
  }
}
