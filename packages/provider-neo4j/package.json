{
  "name": "@cyphra/provider-neo4j",
  "version": "0.2.0",
  "description": "Neo4j (Bolt) provider for Cyphra — CyphraClient on neo4j-driver",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cyphra/core": "workspace:*",
    "@cyphra/query": "workspace:*",
    "neo4j-driver": "^5.27.0"
  },
  "devDependencies": {
    "@testcontainers/neo4j": "^10.16.0",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2"
  },
  "keywords": [
    "cyphra",
    "neo4j",
    "cypher",
    "graph"
  ],
  "license": "MIT",
  "homepage": "https://www.cyphra.dev",
  "bugs": {
    "url": "https://github.com/cyphra-dev/cyphra/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cyphra-dev/cyphra.git",
    "directory": "packages/provider-neo4j"
  }
}
